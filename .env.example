# Database (Neon Postgres)
POSTGRES_URL=  # postgresql://user:pass@host/db?sslmode=require

# Auth.js
AUTH_SECRET=  # Generate with: openssl rand -base64 32
AUTH_URL=     # Production URL, e.g. https://commute-dashboard-nine.vercel.app
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Allowed GitHub username(s), comma-separated
ALLOWED_GITHUB_USERS=chenrui333

# Weather API (Open-Meteo is free, no key needed)
# If using OpenWeatherMap instead:
# OPENWEATHER_API_KEY=

# Google Calendar (optional)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Push Notifications (optional - generate with: bunx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=  # Same as VAPID_PUBLIC_KEY

# GTFS-RT (optional — PATH protobuf feed URL)
GTFSRT_FEED_URL=

# Cron endpoint security (REQUIRED in production)
CRON_SECRET=  # Generate with: openssl rand -hex 16

# Feature request → GitHub issue auto-filing (optional)
AUTO_FILE_GH_ISSUES=false
GITHUB_TOKEN=      # Fine-grained PAT with issues:write scope
GITHUB_OWNER=ruilab
GITHUB_REPO=commute-dashboard

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
